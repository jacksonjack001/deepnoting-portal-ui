# AI Proxy Portal example environment.
# Copy this file to .env and replace placeholder values before production use.

# Portal
PORTAL_BASE_URL=http://127.0.0.1:8090
PORTAL_BIND_HOST=127.0.0.1
PORTAL_PORT=8090
PORTAL_DB_PATH=portal/data/portal.db
PORTAL_SITE_NAME=AI Proxy Portal
PORTAL_ADMIN_TOKEN=change-me-admin-token

# LiteLLM
LITELLM_BASE_URL=http://127.0.0.1:4000
LITELLM_PUBLIC_BASE_URL=http://127.0.0.1:4000
LITELLM_MASTER_KEY=change-me-litellm-master-key

# Optional external service status API.
RESOURCE_STATUS_URL=

# Optional payment gateway. Leave blank to disable paid order creation.
ZPAY_GATEWAY=https://example-payment-gateway.invalid/
ZPAY_PID=
ZPAY_KEY=

# Optional email provider. Leave blank to skip email sending.
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=
TENCENT_SES_ENDPOINT=https://ses.tencentcloudapi.com/
TENCENT_SES_REGION=ap-guangzhou
TENCENT_SES_FROM="AI Proxy <no-reply@example.com>"
TENCENT_SES_REPLY_TO=support@example.com
TENCENT_SES_TEMPLATE_ID=
TENCENT_SES_RESET_TEMPLATE_ID=

# Refund calculation defaults.
PORTAL_REFUND_CHANNEL_FEE_RATE=0.006
PORTAL_REFUND_CHANNEL_FEE_FIXED_CNY=0
PORTAL_REFUND_CHANNEL_FEE_MIN_CNY=0.01
