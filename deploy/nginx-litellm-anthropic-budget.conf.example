# Add the relevant locations inside the existing Nginx server blocks.
#
# LiteLLM currently rejects over-budget keys on /v1/chat/completions, but the
# Anthropic-compatible /v1/messages route can bypass that budget check. Route
# Claude Code traffic through the portal proxy so the key budget is checked
# before forwarding to LiteLLM.

# Add inside the llm.example.com HTTPS server block.
location = /v1/messages {
    proxy_pass http://127.0.0.1:8090/anthropic/v1/messages;
    proxy_set_header Host example.com;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_buffering off;
    proxy_request_buffering off;
    proxy_read_timeout 600s;
}

location = /v1/messages/count_tokens {
    proxy_pass http://127.0.0.1:8090/anthropic/v1/messages/count_tokens;
    proxy_set_header Host example.com;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_buffering off;
    proxy_request_buffering off;
    proxy_read_timeout 120s;
}

# Add inside the example.com HTTPS server block before location /api/.
location = /api/v1/messages {
    proxy_pass http://127.0.0.1:8090/anthropic/v1/messages;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_buffering off;
    proxy_request_buffering off;
    proxy_read_timeout 600s;
}

location = /api/v1/messages/count_tokens {
    proxy_pass http://127.0.0.1:8090/anthropic/v1/messages/count_tokens;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_buffering off;
    proxy_request_buffering off;
    proxy_read_timeout 120s;
}

# Add inside any public fallback LiteLLM server block, such as listen 8180.
location = /v1/messages {
    proxy_pass http://127.0.0.1:8090/anthropic/v1/messages;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_buffering off;
    proxy_request_buffering off;
    proxy_read_timeout 600s;
}

location = /v1/messages/count_tokens {
    proxy_pass http://127.0.0.1:8090/anthropic/v1/messages/count_tokens;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_buffering off;
    proxy_request_buffering off;
    proxy_read_timeout 120s;
}
